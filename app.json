{
  "expo": {
    "name": "Fynx Elite",
    "slug": "fynx",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#000000",
      "resizeMode": "cover"
    },
    "android": {
      "splash": {
        "backgroundColor": "#000000"
      },
      "package": "com.fynx.elite",
      "versionCode": 39,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "windowLayoutInDisplayCutoutMode": "default"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fynx.elite",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Fynx necesita acceso a tu cámara para escanear recibos.",
        "NSPhotoLibraryUsageDescription": "Fynx necesita acceso a tu galería para escanear recibos guardados.",
        "NSFaceIDUsageDescription": "Permite usar Face ID para desbloquear Fynx de forma rápida y segura.",
        "NSUserTrackingUsageDescription": "Fynx necesita tu permiso para rastrear tu actividad y ofrecerte anuncios personalizados que financian el sistema.",
        "NSMicrophoneUsageDescription": "Fynx necesita acceso al micrófono para que puedas enviar mensajes de voz a la IA.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.184364852664-f3b6p4on3fr7jggg2t9gc61uv85vt01c"
            ]
          }
        ]
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAd1Registration.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4AF37"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permite usar Face ID para desbloquear Fynx de forma rápida y segura."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4592841309124858~8849945460",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "FynxWidget",
              "label": "Fynx Resumen",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "Muestra un resumen de tu actividad en Fynx.",
              "previewImage": "./assets/icon.png"
            }
          ]
        }
      ],
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-audio",
      "expo-apple-authentication",
      "expo-tracking-transparency",
      "expo-localization",
      "expo-sharing",
      "expo-asset",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "40d8a702-a426-4da2-be28-c6116ef2af05"
      }
    }
  }
}
